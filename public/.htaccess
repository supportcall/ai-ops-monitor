<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Protect PHP backend from direct access via frontend
<FilesMatch "\.(php|sqlite|db|log)$">
  Order Deny,Allow
  Deny from all
</FilesMatch>
